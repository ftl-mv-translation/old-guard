#: src-en/data/text_tooltips.xml.append:144
msgid ""
"data/text_tooltips.xml.append$//text[@name=\"og_lua_turret_hidename_dd_falseradiance\"]"
msgstr ""
"And then, upon the eighth day... your enemies cried out, with an ardent "
"voice - pleading for salvation. It would never come."

#: src-en/data/text_tooltips.xml.append:145
