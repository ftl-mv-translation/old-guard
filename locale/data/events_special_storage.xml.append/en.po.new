#: src-en/data/events_special_storage.xml.append:574
msgid ""
"data/events_special_storage.xml.append$/dummyroot/FTL/event[@name=\"STORAGE_CHECK_AUG_OG_BOSS_SPAWNER_1\"]/text"
msgstr ""
"You check what ships are available to be summoned currently. Summoning an MV"
" boss will take 7{."

#: src-en/data/events_special_storage.xml.append:576
msgid ""
"data/events_special_storage.xml.append$/dummyroot/FTL/event[@name=\"STORAGE_CHECK_AUG_OG_BOSS_SPAWNER_1\"]/choice[1]/text"
msgstr "Raider Class C - Drops Light Charger Turret"

#: src-en/data/events_special_storage.xml.append:578
msgid ""
"data/events_special_storage.xml.append$/dummyroot/FTL/event[@name=\"STORAGE_CHECK_AUG_OG_BOSS_SPAWNER_1\"]/choice[1]/event/text"
msgstr ""
"You power up the machine to max and watch as a rift opens, shaking the ship "
"until suddenly it powers off, and a flashing green light followed by a "
"string of coordinates signifies that it has worked."

#: src-en/data/events_special_storage.xml.append:586
msgid ""
"data/events_special_storage.xml.append$/dummyroot/FTL/event[@name=\"STORAGE_CHECK_AUG_OG_BOSS_SPAWNER_1\"]/choice[2]/text"
msgstr "Nevermind, do something else."

