#: src-en/data/events_special_storage.xml.append:639
msgid ""
"data/events_special_storage.xml.append$//mod:findName[@name=\"STORAGE_CHECK_JOB_FLEET\"]/mod-"
"append:choice/text"
msgstr ""
"Use your Shard Launcher Turret and additional missiles. [-5}, gives 1 delay,"
" does not impact notoriety]"

#: src-en/data/events_special_storage.xml.append:641
msgid ""
"data/events_special_storage.xml.append$//mod:findName[@name=\"STORAGE_CHECK_JOB_FLEET\"]/mod-"
"append:choice/event/text"
msgstr ""
"You rig the ammunition and set a trap for the Rebels. Fortunately, due to "
"obscure legal loopholes, the use of this weapon isn't illegal, though it is "
"very morally dubious."
