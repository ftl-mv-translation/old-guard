msgid ""
"data/events_special_storage.xml.append$//mod:findName[@name=\"STORAGE_CHECK_REAL\"]/mod-"
"append:choice/text"
msgstr "(Cargo Crate) Open the Cargo Crate."

#: src-en/data/events_special_storage.xml.append:598
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"STORAGE_CHECK_OG_DAWN_CARGO_CRATE_PREIGN\"]/text"
msgstr ""
"Are you sure you want to do this? It's unlikely the people you're delivering"
" it to will be happy with you after this."

#: src-en/data/events_special_storage.xml.append:600
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"STORAGE_CHECK_OG_DAWN_CARGO_CRATE_PREIGN\"]/choice[1]/text"
msgstr "Do it!"

#: src-en/data/events_special_storage.xml.append:602
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"STORAGE_CHECK_OG_DAWN_CARGO_CRATE_PREIGN\"]/choice[1]/event/text"
msgstr ""
"You open the crate to discover a jumble of components and parts, the only "
"thing useable is a half dismantled Turret Pre-energiser, which you're able "
"to get back into working order, the rest is useless to you."

#: src-en/data/events_special_storage.xml.append:608
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"STORAGE_CHECK_OG_DAWN_CARGO_CRATE_PREIGN\"]/choice[2]/text"
msgstr "Nevermind."

