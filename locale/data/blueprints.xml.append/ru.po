"data/blueprints.xml.append$//shipBlueprint[@name=\"PLAYER_SHIP_OG_DAWN_BIG\"]/desc"
msgstr ""
"Благодаря четырем отдельным турелям на главной линии, этот корабль способен "
"сражаться на равных с любым противником."

#: src-en/data/blueprints.xml.append:4789
