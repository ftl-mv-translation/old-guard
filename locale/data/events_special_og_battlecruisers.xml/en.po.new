#: src-en/data/events_special_og_battlecruisers.xml:32
msgid ""
"data/events_special_og_battlecruisers.xml$//event[@name=\"NEBULA_OG_BATTLECRUISER_SLUG\"]/text"
msgstr ""
"A Battlecruiser wielding powerful Turret tech is sitting at this beacon. The"
" Kleptocracy aren't known as honest merchants, so you doubt this particular "
"slug got his hands on those turrets fairly."

#: src-en/data/events_special_og_battlecruisers.xml:35
msgid ""
"data/events_special_og_battlecruisers.xml$//event[@name=\"NEBULA_OG_BATTLECRUISER_SLUG\"]/choice[1]/text"
msgstr "Attack, we can steal their Turret tech!"

