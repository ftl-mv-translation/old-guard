#: src-en/data/events_special_og_battlecruisers.xml:9
msgid ""
"data/events_special_og_battlecruisers.xml$//event[@name=\"DESTROYED_OG_BATTLECRUISER_SLUG\"]/text"
msgstr ""
"While scrapping the wreckage of the Battlecruiser, you find a functional "
"Turret drifting in the midst of the wreckage."

#: src-en/data/events_special_og_battlecruisers.xml:16
msgid ""
"data/events_special_og_battlecruisers.xml$//event[@name=\"DEAD_CREW_OG_BATTLECRUISER_SLUG\"]/text"
msgstr ""
"The Battlecruiser has been emptied of crew. While scrapping it, you find a "
"Turret in its storage."

