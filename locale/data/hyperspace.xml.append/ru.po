#: src-en/data/hyperspace.xml.append:1040
msgid ""
"data/hyperspace.xml.append$//race[@name=\"human_og_dawn\"]/powerEffect/buttonText"
msgstr "МАСКИРОВКА"

#: src-en/data/hyperspace.xml.append:1041
msgid ""
"data/hyperspace.xml.append$//race[@name=\"human_og_dawn\"]/powerEffect/tooltip"
msgstr ""
"[ПЕРЕЗАРЯДКА: 30с  ДЛИТЕЛЬНОСТЬ: 15с]\n"
"\t\t\t\tДает следующие эффекты:\n"
"\t\t\t\t-Избегает нацеливания со стороны экипажа.\n"
"\t\t\t\t-Урон увеличивается на 50%\n"
"\t\t\t\t-Скорость саботажа увеличивается на 25%\n"
"\t\t\t\t-Пассивно восстанавливает перезарядку Маскировки.\n"
"\t\t\t\t-Продолжительность Маскировки сокращается при следующих действиях:\n"
"\t\t\t\t\t-Атака - 1x\n"
"\t\t\t\t\t-Ремонт - 0.75x\n"
"\t\t\t\t\t-Перемещение - 0.25x"

