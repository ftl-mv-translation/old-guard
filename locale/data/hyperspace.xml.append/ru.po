#: src-en/data/hyperspace.xml.append:553
msgid ""
"data/hyperspace.xml.append$//achievement[@name=\"SHIP_ACH_OG_DAWN_BIG_3\"]/name"
msgstr "Это моя винтовка, это мое оружие!"

#: src-en/data/hyperspace.xml.append:554
msgid ""
"data/hyperspace.xml.append$//achievement[@name=\"SHIP_ACH_OG_DAWN_BIG_3\"]/description"
msgstr ""
"На корабле класса \"Колосс\": улучшите все свои большие турели до 5-й "
