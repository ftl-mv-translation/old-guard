#: src-en/data/hyperspace.xml.append:547
msgid ""
"data/hyperspace.xml.append$//achievement[@name=\"SHIP_ACH_OG_DAWN_BIG_2\"]/name"
msgstr "Одновременная атака"

#: src-en/data/hyperspace.xml.append:548
msgid ""
"data/hyperspace.xml.append$//achievement[@name=\"SHIP_ACH_OG_DAWN_BIG_2\"]/description"
msgstr ""
"На корабле класса \"Колосс\": установите одинаковые турели во всех слотах "
