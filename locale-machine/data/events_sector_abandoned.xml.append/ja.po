#: src-en/data/events_sector_abandoned.xml.append:7
msgid ""
"data/events_sector_abandoned.xml.append$//event[@name=\"ENCOUNTER_OG_IRON_ABANDONED\"]/text"
msgstr "到着時、アイアンウォッチの艦がこのビーコンを探索中だった。彼らは警戒を怠らず、即座に兵器を作動させた。"

#: src-en/data/events_sector_abandoned.xml.append:10
msgid ""
"data/events_sector_abandoned.xml.append$//event[@name=\"ENCOUNTER_OG_IRON_ABANDONED\"]/choice[@req=\"rep_comb_og_iron\""
" and @lvl=\"-999\"]/text"
msgstr "次へ…"

#: src-en/data/events_sector_abandoned.xml.append:14
msgid ""
"data/events_sector_abandoned.xml.append$//event[@name=\"ENCOUNTER_OG_IRON_ABANDONED\"]/choice[@req=\"rep_comb_og_iron\""
" and @lvl=\"2\"]/text"
msgstr "次へ…"

#: src-en/data/events_sector_abandoned.xml.append:17
msgid ""
"data/events_sector_abandoned.xml.append$//event[@name=\"ENCOUNTER_OG_IRON_ABANDONED\"]/choice[@req=\"rep_comb_og_iron\""
" and @lvl=\"2\"]/event/text"
msgstr "幸い、彼らは君の評判を知っており、すぐに認識した。見つけたサルベージを分け合おうと提案してくる。"

#: src-en/data/events_sector_abandoned.xml.append:20
msgid ""
"data/events_sector_abandoned.xml.append$//event[@name=\"ENCOUNTER_OG_IRON_ABANDONED\"]/choice[@req=\"rep_comb_og_iron\""
" and @lvl=\"2\"]/event/choice[1]/text"
msgstr "それでも攻撃する。"

#: src-en/data/events_sector_abandoned.xml.append:22
msgid ""
"data/events_sector_abandoned.xml.append$//event[@name=\"ENCOUNTER_OG_IRON_ABANDONED\"]/choice[@req=\"rep_comb_og_iron\""
" and @lvl=\"2\"]/event/choice[1]/event/text"
msgstr "サルベージを受け取った後、兵器を起動する。通信越しに聞こえる罵詈雑言の数から、アイアンウォッチが君の裏切りに激怒していることは明白だ。"

#: src-en/data/events_sector_abandoned.xml.append:25
msgid ""
"data/events_sector_abandoned.xml.append$//event[@name=\"ENCOUNTER_OG_IRON_ABANDONED\"]/choice[@req=\"rep_comb_og_iron\""
" and @lvl=\"2\"]/event/choice[1]/event/choice/text"
msgstr "次へ…"

#: src-en/data/events_sector_abandoned.xml.append:31
msgid ""
"data/events_sector_abandoned.xml.append$//event[@name=\"ENCOUNTER_OG_IRON_ABANDONED\"]/choice[@req=\"rep_comb_og_iron\""
" and @lvl=\"2\"]/event/choice[2]/text"
msgstr "艦内で行う行動を選択する。"

#: src-en/data/events_sector_abandoned.xml.append:35
msgid ""
"data/events_sector_abandoned.xml.append$//event[@name=\"ENCOUNTER_OG_IRON_ABANDONED\"]/choice[@req=\"rep_comb_og_iron\""
" and @lvl=\"2\"]/event/choice[3]/text"
msgstr "何もしない。"
