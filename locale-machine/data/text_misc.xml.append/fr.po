#: src-en/data/text_misc.xml.append:30
msgid "data/text_misc.xml.append$//text[@name=\"loot_og_dawn_1\"]"
msgstr ""
"BUTIN NEW DAWN\n"
"Applique la vulnérabilité aux pièces touchées pendant 5 secondes\n"
"-1 seconde de temps de recharge"

#: src-en/data/text_misc.xml.append:34
msgid "data/text_misc.xml.append$//text[@name=\"og_turret_loot_slug_1\"]"
msgstr ""
"BUTIN LIMACE\n"
"+1 dégât système, +15 dégâts équipage\n"
"+20 % chance de brèche"

#: src-en/data/text_misc.xml.append:37
msgid "data/text_misc.xml.append$//text[@name=\"og_turret_loot_clan_1\"]"
msgstr ""
"BUTIN CLAN\n"
"Étourdit l'équipage touché pendant 3 secondes\n"
"+120 guidage\n"
"-0.5 seconde de temps de recharge"

#: src-en/data/text_misc.xml.append:41
msgid "data/text_misc.xml.append$//text[@name=\"og_turret_loot_crystal_1\"]"
msgstr ""
"BUTIN CRISTALIEN\n"
"Tire des Mines Cristallines\n"
"+120 guidage\n"
"+1 projectile\n"
"+5 secondes de temps de recharge"

#: src-en/data/text_misc.xml.append:47
msgid "data/text_misc.xml.append$//text[@name=\"og_turret_loot_federation_1\"]"
msgstr ""
"BUTIN FÉDÉRATION\n"
"Peut cibler tous les projectiles et drones\n"
"+2 charges\n"
"-1 seconde de temps de recharge"

