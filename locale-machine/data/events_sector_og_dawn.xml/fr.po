#: src-en/data/events_sector_og_dawn.xml:1594
msgid ""
"data/events_sector_og_dawn.xml$//event[@name=\"OG_DAWN_PREIGN_QUEST_DESTINATION\"]/choice[1]/event/choice[1]/event/text"
msgstr "\"Oh, eh bien où est la caisse de chargement alors ?\""

#: src-en/data/events_sector_og_dawn.xml:1596
msgid ""
"data/events_sector_og_dawn.xml$//event[@name=\"OG_DAWN_PREIGN_QUEST_DESTINATION\"]/choice[1]/event/choice[1]/event/choice[@req=\"OG_CARGO_CRATE_PREIGN_WEAK\"]/text"
msgstr "(Caisse de chargement) Lui montrer la caisse de chargement."

#: src-en/data/events_sector_og_dawn.xml:1598
msgid ""
"data/events_sector_og_dawn.xml$//event[@name=\"OG_DAWN_PREIGN_QUEST_DESTINATION\"]/choice[1]/event/choice[1]/event/choice[@req=\"OG_CARGO_CRATE_PREIGN_WEAK\"]/event/text"
msgstr ""
"\"Oh, vous ne mentiez pas, la voilà, apportez-la et suivez-moi, ce n'est pas loin d'ici.\"\n"
"\n"
"Un instant plus tard, vous vous retrouvez dans un laboratoire à l'aspect étrange, il y a plusieurs tables sans surveillance autour de la pièce, mais vous êtes dirigé vers une table légèrement plus grande au milieu."

#: src-en/data/events_sector_og_dawn.xml:1602
msgid ""
"data/events_sector_og_dawn.xml$//event[@name=\"OG_DAWN_PREIGN_QUEST_DESTINATION\"]/choice[1]/event/choice[1]/event/choice[@req=\"OG_CARGO_CRATE_PREIGN_WEAK\"]/event/choice/text"
