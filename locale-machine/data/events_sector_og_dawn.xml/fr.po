"data/events_sector_og_dawn.xml$//event[@name=\"STOREEVENT_OG_DAWN_TURRET_COVERUP\"]/choice[@req=\"sensors\"]/text"
msgstr "(Capteurs de pointe) Scanner la tourelle à distance."

#: src-en/data/events_sector_og_dawn.xml:514
msgid ""
"data/events_sector_og_dawn.xml$//event[@name=\"STOREEVENT_OG_DAWN_TURRET_COVERUP\"]/choice[@req=\"sensors\"]/event/text"
msgstr ""
