"pouvez faire quelques achats."

#: src-en/data/events_sector_og_dawn.xml:520
msgid ""
"data/events_sector_og_dawn.xml$//event[@name=\"STOREEVENT_OG_DAWN_TURRET_COVERUP_REPORT\"]/choice/text"
