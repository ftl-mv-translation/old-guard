"spécifique où se diriger."

#: src-en/data/events_sector_og_dawn.xml:1588
msgid ""
"data/events_sector_og_dawn.xml$//event[@name=\"OG_DAWN_PREIGN_QUEST_DESTINATION\"]/choice[1]/text"
