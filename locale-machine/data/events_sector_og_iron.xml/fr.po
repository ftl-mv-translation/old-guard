msgid ""
"data/events_sector_og_iron.xml$//event[@name=\"OG_IRON_PROTOTYPE_DESTINATION\"]/choice/event/choice[3]/text"
msgstr "Se retirer à une distance de sécurité et rester hors du combat."

#: src-en/data/events_sector_og_iron.xml:1857
msgid ""
"data/events_sector_og_iron.xml$//event[@name=\"OG_IRON_PROTOTYPE_DESTINATION\"]/choice/event/choice[3]/event/text"
msgstr ""
"Vous vous éloignez des deux vaisseaux et vous préparez pour votre prochain "
"saut."

#: src-en/data/events_sector_og_iron.xml:1860
