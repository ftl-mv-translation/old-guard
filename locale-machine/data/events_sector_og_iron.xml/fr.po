msgid ""
"data/events_sector_og_iron.xml$//event[@name=\"OG_IRON_DELIVERY_OUTPOST\"]/choice[@req=\"LIST_CHECK_ANY_CREW\""
" and @lvl=\"1\"]/event/choice[@req=\"OG_TURRET_LASER_MINI_DAWN_2\" and "
"not(@lvl)]/event/text"
msgstr ""
"\"Oh Dieu merci, comment dans le multivers avez-vous pu la trouver ?\" Vous "
